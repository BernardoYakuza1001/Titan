<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- MoonPay widget is a hosted WebView; needs network. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@android:style/Theme.Material.NoActionBar">

        <!-- Kiosk home: registering as HOME makes this selectable as the device
             launcher; combined with lock-task (device-owner provisioning) this is
             the single-app COSU surface from Phase 2. -->
        <activity
            android:name=".LauncherActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:stateNotNeeded="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ProfileActivity"
            android:exported="false" />

        <!-- Viva Smart Checkout: creates an order then hosts Viva's checkout page. -->
        <activity
            android:name=".VivaCheckoutActivity"
            android:exported="false" />
    </application>
</manifest>

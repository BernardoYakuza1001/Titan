# =============================================================================
# PROJECT TITAN — backend configuration TEMPLATE.
# Copy to `.env` and fill with YOUR values. `.env` is gitignored — NEVER commit
# real secrets. In production these come from a secrets manager (Vault / AWS
# Secrets Manager / GCP Secret Manager), not a file.
#
# Run the API with:   node --env-file=.env dist/services/bootstrap/main.js
# (Node 20.6+ reads --env-file natively; no dotenv dependency needed.)
# =============================================================================

# ---- Environment ------------------------------------------------------------
PORT=3000

# ---- Viva Wallet — START IN DEMO. Only switch to live after a successful demo
#      run AND your acquirer/PCI onboarding is complete. ------------------------
#
# Viva has TWO credential pairs:
#   * OAuth2 client-credentials (Client ID + Secret) -> the modern API. THIS is
#     what Titan's adapter + token provider use.
#   * Basic auth (Merchant ID + API Key) -> native-checkout / some legacy calls.
#
# DEMO hosts (use these first):
VIVA_ACCOUNTS_URL=https://demo-accounts.vivapayments.com/connect/token
VIVA_BASE_URL=https://demo-api.vivapayments.com
# LIVE hosts (DO NOT use until demo passes + you are licensed/onboarded):
#   VIVA_ACCOUNTS_URL=https://accounts.vivapayments.com/connect/token
#   VIVA_BASE_URL=https://api.vivapayments.com

# OAuth2 (used by VivaOAuthTokenProvider + the charge/tokenize adapters):
VIVA_CLIENT_ID=your-demo-client-id.apps.vivapayments.com
VIVA_CLIENT_SECRET=your-demo-client-secret

# Basic-auth pair (native-checkout flows). Fill if/when those endpoints are used:
VIVA_MERCHANT_ID=your-merchant-id
VIVA_API_KEY=your-api-key

# Payment source code created in the Viva portal (per merchant). REQUIRED.
VIVA_SOURCE_CODE=your-source-code

# Charge auth scheme: 'basic' (Native Checkout, Merchant ID + API Key) or 'oauth'
# (Bearer; requires the OAuth app's charge scopes enabled in the Viva portal).
VIVA_AUTH_SCHEME=basic
VIVA_NATIVE_CHECKOUT_PATH=/nativecheckout/v2/transactions

# Confirm against your Viva account's API docs (illustrative default):
VIVA_TRANSACTIONS_PATH=/checkout/v2/transactions
VIVA_TOKENIZE_PATH=/acquiring/v1/cards/tokens

# Smart Checkout hosted-order flow (Basic auth). Demo defaults; live = www.vivapayments.com
VIVA_ORDERS_URL=https://demo.vivapayments.com/api/orders
VIVA_CHECKOUT_URL=https://demo.vivapayments.com/web/checkout

# ---- Device auth (terminal session JWTs) ------------------------------------
# Demo HS256 secret. Production: switch JwtDeviceVerifier to RS256 and verify
# with the Auth service's PUBLIC key (no shared secret on the acquiring service).
DEVICE_JWT_SECRET=generate-a-long-random-secret

# ---- Database ---------------------------------------------------------------
DATABASE_URL=postgres://titan:password@localhost:5432/titan

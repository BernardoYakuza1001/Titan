{
  "name": "@titan/backend",
  "version": "0.1.0",
  "scripts": {
    "build": "tsc -b",
    "typecheck:test": "tsc -p tsconfig.spec.json --noEmit",
    "test": "npm run typecheck:test && jest"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@noble/hashes": "^1.8.0",
    "@scure/base": "^1.2.6",
    "@titan/profile-schema": "*",
    "class-validator": "^0.14.0",
    "kafkajs": "^2.2.0",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "jest": "^29.7.0",
    "pg-mem": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "testEnvironment": "node",
    "rootDir": ".",
    "roots": [
      "<rootDir>/libs",
      "<rootDir>/services",
      "<rootDir>/test"
    ],
    "testMatch": [
      "**/*.spec.ts"
    ],
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^@titan/profile-schema$": "<rootDir>/../../packages/profile-schema/src/index.ts"
    },
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "isolatedModules": true,
          "tsconfig": "<rootDir>/tsconfig.json"
        }
      ]
    }
  }
}

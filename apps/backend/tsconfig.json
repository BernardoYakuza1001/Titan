{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declaration": true,
    "composite": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@titan/profile-schema": ["../../packages/profile-schema/src"]
    }
  },
  "references": [
    { "path": "../../packages/profile-schema" }
  ],
  "include": ["libs", "services"]
}
